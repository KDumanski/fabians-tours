# Copy to .env.local for local dev (never commit .env.local — it's gitignored).
# On Vercel, set these in Project → Settings → Environment Variables instead.

# --- Database (Vercel Postgres auto-sets POSTGRES_URL when you add the store) ---
POSTGRES_URL="postgres://user:pass@host/db?sslmode=require"

# --- Auth.js (NextAuth) ---
# Generate a secret with:  npx auth secret    (or: openssl rand -base64 32)
AUTH_SECRET="replace-with-a-long-random-string"
# From Google Cloud Console → Credentials → OAuth client (see DEPLOY-VERCEL.md)
AUTH_GOOGLE_ID="xxxxxxxx.apps.googleusercontent.com"
AUTH_GOOGLE_SECRET="xxxxxxxx"

# --- Image uploads (Vercel Blob auto-sets this when you add Blob storage) ---
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxx"

# --- Optional ---
# Extra admin emails beyond the built-in allowlist (comma-separated)
# ADMIN_EMAILS="someone@example.com,another@example.com"
# Canonical site URL (used for sitemap/robots/OG). Defaults to the .vercel.app URL.
# SITE_URL="https://fabians-tours.vercel.app"
